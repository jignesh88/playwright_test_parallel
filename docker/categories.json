[
  {
    "name": "Selector / locator failures",
    "matchedStatuses": ["failed", "broken"],
    "messageRegex": ".*(?:getBy(?:TestId|Role|Text|Label)|locator|toBeVisible|toBeAttached|toBeChecked|toHaveText|toHaveURL).*"
  },
  {
    "name": "Assertion timeouts",
    "matchedStatuses": ["failed"],
    "messageRegex": ".*Timed out \\d+m?s waiting for.*"
  },
  {
    "name": "Insufficient funds / data contention",
    "matchedStatuses": ["failed"],
    "messageRegex": ".*insufficient funds.*"
  },
  {
    "name": "Authentication failures",
    "matchedStatuses": ["failed", "broken"],
    "messageRegex": ".*(?:Invalid credentials|Missing token|Invalid token|401 Unauthorized).*"
  },
  {
    "name": "Network / backend errors",
    "matchedStatuses": ["failed", "broken"],
    "messageRegex": ".*(?:ECONNREFUSED|ETIMEDOUT|ENOTFOUND|500 Internal|503 Service|net::ERR_).*"
  },
  {
    "name": "Browser launch failures",
    "matchedStatuses": ["broken"],
    "messageRegex": ".*browserType\\.launch.*"
  },
  {
    "name": "Test infrastructure (BDD generation / fixture errors)",
    "matchedStatuses": ["broken"],
    "messageRegex": ".*(?:bddgen|fixture|Cannot find module).*"
  }
]
